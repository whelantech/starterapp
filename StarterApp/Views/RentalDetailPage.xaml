<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.RentalDetailPage"
             Title="{Binding Title}">

    <Grid>
        <RefreshView IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <ScrollView IsVisible="{Binding Rental, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Padding="20" Spacing="16">

                    <Label Text="{Binding Rental.ItemTitle}"
                           FontSize="24"
                           FontAttributes="Bold"
                           LineBreakMode="WordWrap" />

                    <Label Text="{Binding Rental.ItemDescription}"
                           FontSize="16"
                           LineBreakMode="WordWrap"
                           IsVisible="{Binding HasItemDescription}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="Status" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Grid.Row="0" Grid.Column="1"
                               HorizontalOptions="End"
                               FontSize="16"
                               Text="{Binding StatusDisplayText}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Renter" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               HorizontalOptions="End"
                               FontSize="16"
                               Text="{Binding Rental.BorrowerName}"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Owner" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               HorizontalOptions="End"
                               FontSize="16"
                               Text="{Binding Rental.OwnerName}"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Dates" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               HorizontalOptions="End"
                               FontSize="16"
                               Text="{Binding DateRangeDisplay}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="Total" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Grid.Row="4" Grid.Column="1"
                               HorizontalOptions="End"
                               FontSize="16"
                               FontAttributes="Bold"
                               Text="{Binding TotalPriceDisplay}" />
                    </Grid>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding HasRequestedAt}">
                        <Label Text="Requested" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Text="{Binding RequestedAtDisplay}" FontSize="16" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding HasComments}">
                        <Label Text="Additional information" FontAttributes="Bold" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Label Text="{Binding Rental.Comments}"
                               FontSize="16"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowOwnerActions}">
                        <Label Text="You own this listing — respond to the request"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <HorizontalStackLayout Spacing="12">
                            <Button Text="Approve"
                                    Command="{Binding ApproveCommand}"
                                    HorizontalOptions="FillAndExpand" />
                            <Button Text="Reject"
                                    Command="{Binding RejectCommand}"
                                    HorizontalOptions="FillAndExpand" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowOwnerApprovedBeforeStart}">
                        <Label Text="The rental period has not started yet. You can mark this listing as out for rent on or after the start date."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowOwnerStartRental}">
                        <Label Text="Start the rental period when the item goes out."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Button Text="Start rental (out for rent)"
                                Command="{Binding StartRentalCommand}"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowBorrowerReturn}">
                        <Label Text="Mark the item as returned when you have given it back to the owner."
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Button Text="Mark returned"
                                Command="{Binding ReturnCommand}"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowOwnerComplete}">
                        <Label Text="Close this rental after return is confirmed."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                        <Button Text="Complete rental"
                                Command="{Binding CompleteCommand}"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <Border Padding="16"
                IsVisible="{Binding HasError}"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                VerticalOptions="Center"
                Margin="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
        </Border>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
    </Grid>
</ContentPage>
